# Database Connection Settings for Tests
# Copy this file to .env and update with your actual values

# Supabase local development defaults (via supabase start)
DB_HOST=localhost
DB_PORT=54322
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Direct connection not possible unless using IPv6. 
# For IPv4 use pooler link:
# postgres://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require"

# DB_HOST=aws-0-[REGION].pooler.supabase.com:5432
# DB_SSLMODE=require
# DB_PROJECT_REF=postgres.[PROJECT ID]
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=[PROJECT DATABASE PASSWORD]


# Alternative: Supabase cloud connection
# DB_HOST=db.your-project-ref.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-database-password

# Alternative: Standard PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=saasdb
# DB_USER=your_username
# DB_PASSWORD=your_password
